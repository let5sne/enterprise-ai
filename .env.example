# --- Core ---
DATABASE_URL=sqlite:///./enterprise_ai.db
DEBUG=false

# --- Local LLM / RAG ---
# Turn on to route content.generate and knowledge.ask through a local
# Ollama server instead of the template / keyword fallbacks.
LLM_ENABLED=false
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b
EMBEDDING_MODEL=bge-m3
VECTOR_DB_PATH=.chroma
KNOWLEDGE_DOCS_DIR=data/knowledge_docs
KNOWLEDGE_COLLECTION=knowledge
